{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(make *)",
      "Bash(go *)",
      "Bash(trash)",
      "Bash(golangci-lint *)",
      "Bash(migrate *)",
      "Bash(docker compose *)",
      "Bash(docker-compose *)",
      "Bash(ls *)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git show *)",
      "Bash(git branch *)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(rm:*)",
      "Bash(git push --force*)",
      "Bash(git reset --hard*)"
    ]
  },
  "skillOverrides": {
    "autoresearch-coding": "user-invocable-only"
  }
}
